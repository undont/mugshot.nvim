{
    "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
    "runtime.version": "LuaJIT",
    "workspace.library": [
        "$VIMRUNTIME/lua",
        "${3rd}/busted/library",
        "${3rd}/luassert/library"
    ],
    "workspace.ignoreDir": [".luacheckrc"],
    "diagnostics.globals": ["vim"],
    "diagnostics.disable": [
        "redundant-parameter"
    ]
}
