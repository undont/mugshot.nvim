return {
    _all = {
        lpath = "lua/?.lua;lua/?/init.lua",
    },
    -- pure-lua units (no nvim runtime): busted
    unit = {
        ROOT = { "test/unit" },
        pattern = "_spec%.lua$",
    },
    default = {
        ROOT = { "test/unit" },
        pattern = "_spec%.lua$",
    },
    -- headless-nvim suite: loads minimal_init first
    nvim = {
        ROOT = { "test/nvim" },
        pattern = "_spec%.lua$",
        helper = "test/nvim/minimal_init.lua",
    },
}
